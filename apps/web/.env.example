# Sanity configuration
# Get these from https://sanity.io/manage
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# Optional: Required only for draft/preview mode
# Create a token at https://sanity.io/manage → API → Tokens
# SANITY_READ_TOKEN=

# Contentbron: false/weg = markdown (src/content), true = Sanity
# Zet pas op true nadat scripts/migrate-alle10top.ts is gedraaid.
USE_SANITY=false

# Alleen nodig voor de migratie (scripts/migrate-alle10top.ts):
# SANITY_WRITE_TOKEN=
