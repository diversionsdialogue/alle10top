---
import "@/styles/global.css";
import Header from "@/components/a10/Header.astro";
import Footer from "@/components/a10/Footer.astro";
import Newsletter from "@/components/a10/Newsletter.astro";
import { SITE } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
  /** Absolute of site-relatieve afbeelding voor social shares */
  image?: string;
  nieuwsbrief?: boolean;
  type?: "website" | "article";
  pubDate?: Date;
}

const {
  title,
  description = SITE.description,
  image,
  nieuwsbrief = true,
  type = "website",
  pubDate,
} = Astro.props;

const paginaTitel = title ? `${title} — ${SITE.name}` : SITE.title;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = image
  ? new URL(image, SITE.url).href
  : new URL("/alle10top-icon.png", SITE.url).href;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{paginaTitel}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/alle10top-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.name}
      href={new URL("rss.xml", SITE.url)}
    />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={paginaTitel} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="nl_NL" />
    {pubDate && (
      <meta
        property="article:published_time"
        content={pubDate.toISOString()}
      />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="kit">
      <Header />
      <slot />
      {nieuwsbrief && <Newsletter />}
      <Footer />
    </div>
  </body>
</html>
